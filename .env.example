# Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
WEBHOOK_SECRET=any-random-string-here

# Group for status reports
GROUP_CHAT_ID=0

# Distance
MAX_DISTANCE_METERS=300

# Turso DB (SQLite in the cloud — free tier)
# Get yours at https://turso.tech
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# For local dev without Turso, leave empty — uses local SQLite
# TURSO_URL=
# TURSO_AUTH_TOKEN=
